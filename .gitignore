# ============================================================================
# Tavoria monorepo — root .gitignore
# Each subproject also has its own .gitignore; this is a belt-and-braces layer.
# ============================================================================

# --- Secrets: NEVER commit ---
.env
.env.*
!.env.example
!.env.local.example
*.pem
*.p8
*.p12
*.jks
*.key
*.mobileprovision

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js (tavoria-web) ---
.next/
out/
next-env.d.ts
*.tsbuildinfo

# --- Expo / React Native (tavoria-worker, tavoria-worker-v2) ---
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# --- Vercel ---
.vercel/

# --- Editor / OS junk ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# --- Build artifacts ---
build/
coverage/
*.log

# --- Local scratch / test outputs ---
tmp/
scratch/
outputs/
